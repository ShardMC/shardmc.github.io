---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Note from '~/components/widgets/Note.astro';
import Features from '~/components/widgets/Features.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Steps from '~/components/widgets/Steps.astro';
import Content from '~/components/widgets/Content.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Stats from '~/components/widgets/Stats.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

import { getPermalink } from '~/utils/permalinks.ts';

const metadata = {
  title: 'ShardMC — Your Minecraft Server Core',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Downloads',
        href: getPermalink('/get'),
        icon: 'tabler:download',
      },
      { text: 'Learn more', href: '#features' },
    ]}
    image={{ src: '~/assets/images/hero.png', alt: 'Hero Image' }}
  >
    <Fragment slot="title">
      ShardMC - Your <br />
      <span class="text-accent dark:text-white highlight">Minecraft</span> Server Core
    </Fragment>

    <Fragment slot="subtitle">
      <span class="hidden sm:inline">
        <span class="font-semibold">ShardMC</span> is an open-source Minecraft Server Core Software, designed to be customizeable
        and very fast!</span
      >
      <span class="block mb-1 sm:hidden font-bold text-cyan-600">ShardMC: Customizeable, Fast.</span>
    </Fragment>
  </Hero>

  <!-- Note Widget ******************* -->

  <Note />

  <!-- Features Widget *************** -->

  <Features
    id="features"
    tagline="Features"
    title="What you get with ShardMC"
    subtitle="ShardMC has a lot of cool features designed for players by players!"
    items={[
      [
        {
          title: 'Customizeable',
          description:
            'Modules allow you to customize the server like you want! Like plugins, but better... and the best part is: modules can add support for your favourite Mod Loaders!',
          icon: 'tabler:adjustments-horizontal',
        },
        {
          title: 'Fast',
          description:
            'ShardMC is designed with speed in mind! We optimized the heavy calculations and some other stuff!',
          icon: 'tabler:bolt',
        },
      ],
      [
        {
          title: 'Open to new ideas',
          description:
            "We are open to communitiy's ideas! If you know how to make this project better: contact us on Discord!",
          icon: 'tabler:bulb',
        },
        {
          title: 'Open Source',
          description: 'ShardMC is open-source! Contributions are welcome!',
          icon: 'tabler:brand-github',
        },
      ],
    ]}
  />

  <!-- Steps Widget ****************** -->

  <Steps
    title="ShardMC Roadmap"
    items={[
      {
        title: 'Echo v0.1R',
        description:
          'First stable release of Echo - bytecode manipulation library for ShardMC, that allows to create modules and modify server\'s code!',
        icon: 'tabler:package',
      },
      {
        title: 'Amethyst v0.1R',
        description: 
          'With the first release of Amethyst, it would be possible to launch the core and attach modules!',
        icon: 'tabler:diamond',
      },
      {
        title: 'Core v0.1R',
        description: 
          'The core of ShardMC.',
        icon: 'tabler:aperture',
      },
      {
        title: 'ShardMC v0.1R',
        icon: 'tabler:hourglass',
      },
    ]}
    image={{
      src: '~/assets/images/warden-thinking.webp',
      alt: 'Steps image',
    }}
  />

  <!-- Features2 Widget ************** -->


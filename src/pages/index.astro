  <!-- HighlightedPosts Widget ******* -->

  <BlogLatestPosts
    title="Blog"
    information={`We post various content on our blog: from development experience to announcements!
      Every time we release a post, it will automatically post it on the Discord server as well!
      You can also find some tutorials and tips there :)
    `}
  />

  <!-- FAQs Widget ******************* -->

  <FAQs
    title="Frequently Asked Questions"
    subtitle=""
    highlight="FAQs"
    classes={{ container: 'max-w-6xl' }}
    items={[
      {
        title: 'When can I try it out?',
        description: "Check our roadmap and blog for current progress! Currently, the answer is: when it's done.",
      },
      {
        title: 'How can I follow for updates?',
        description: `You can check out our <a href="https://discord.gg/CqVAzakrqx" class="text-accent">Discord</a>, <a href="/blog" class="text-accent">Blog</a> and even <a href="/rss.xml" class="text-accent">RSS</a>!`,
      },
      {
        title: 'I have an idea! Where can I share it?',
        description: `You can find everything you need in <span class="text-accent">#❗┆read-me</span> channel in our Discord server!`,
      },
    ]}
  />

